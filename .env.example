# ============================================================
# Customer Support Agent — environment template
# Copy to `.env` and fill in real values. Never commit `.env`.
# ============================================================

# --- LLM (OpenAI-compatible) ---------------------------------
# Works with OpenAI, Azure OpenAI (compatibility endpoint),
# OpenRouter, Together, Groq, vLLM, Ollama, etc.
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=60
AGENT_MAX_STEPS=6

# --- Embeddings (local, runs in API + ingest) ----------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Postgres ------------------------------------------------
POSTGRES_USER=support
POSTGRES_PASSWORD=support
POSTGRES_DB=support
DATABASE_URL=postgresql+psycopg://support:support@postgres:5432/support

# --- Qdrant --------------------------------------------------
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=amazon_products_2023
RAG_TOP_K=6

# --- Email (Mailhog — local fake inbox; no SES needed) -----
# Requires: docker compose --profile dev-mail up -d (starts the mailhog service).
# Browser UI: http://localhost:8025 — all SMTP from the app lands there.
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@local.test

# --- Optional escalation webhook (Slack/MS Teams/etc.) -------
ESCALATION_WEBHOOK_URL=

# --- App -----------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info
CORS_ORIGINS=*
